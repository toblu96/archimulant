# Scenarios directory
NUXT_SCENARIOS_DIR=server/data/scenarios

# Better-auth Secret (required for production, generates one if not set in dev)
BETTER_AUTH_SECRET=

# Better-auth OAuth (optional for local dev, required for production)
NUXT_AUTH_GOOGLE_CLIENT_ID=
NUXT_AUTH_GOOGLE_CLIENT_SECRET=
NUXT_AUTH_GITHUB_CLIENT_ID=
NUXT_AUTH_GITHUB_CLIENT_SECRET=

# Database path (default: .data/auth.db)
NUXT_AUTH_DATABASE_FILE_PATH=.data/auth.db

# Auto-run auth migrations on startup
NUXT_AUTH_AUTO_MIGRATE=true
