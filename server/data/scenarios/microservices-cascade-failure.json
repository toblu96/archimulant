          "effects": { "failRate": 0.002 }
        }
      ]
    },
    {
      "id": "split-database",
      "title": "Split Shared Database",
      "description": "Give each service its own database schema and connection pool. Eliminates resource contention between Order and Payment services on the shared database.",
