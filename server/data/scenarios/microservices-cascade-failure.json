  "improvements": [
    {
      "id": "circuit-breaker-payment",
      "title": "Add Circuit Breaker on Payment Service",
      "description": "Wrap calls to the Payment Service with a circuit breaker. When error rates exceed a threshold the circuit opens, failing fast instead of queueing threads — protecting the Order Service from cascading failure.",
      "learnMoreSlug": "circuit-breaker",
      "cost": { "yearlyOperational": 400, "oneTimeInvestment": 800 },
      "appliesTo": [
        {
          "targetId": "gateway-payment",
          "effects": { "latencyMs": -5, "failRate": -0.01 }
        },
        {
          "targetId": "api-gateway",
          "effects": { "latencyMs": 1 }
        }
      ]
    },
    {
      "id": "bulkhead-order",
      "title": "Apply Bulkhead to Order Service",
      "description": "Isolate thread pools per dependency in the Order Service. A slow Payment Service can no longer exhaust the shared thread pool and block order processing.",
      "learnMoreSlug": "bulkhead-pattern",
      "cost": { "yearlyOperational": 600, "oneTimeInvestment": 1200 },
      "appliesTo": [
        {
          "targetId": "order-service",
          "effects": { "availability": 0.8, "throughputRps": 250, "latencyMs": -20 }
        },
        {
          "targetId": "gateway-order",
          "effects": { "latencyMs": 3, "failRate": 0.001 }
        }
      ]
    },
    {
      "id": "scale-payment-service",
      "title": "Scale Payment Service",
      "description": "Run additional Payment Service instances to handle the high processing load and reduce per-instance latency.",
      "learnMoreSlug": "horizontal-scaling",
      "cost": { "yearlyOperational": 1800, "oneTimeInvestment": 1500 },
      "appliesTo": [
        {
          "targetId": "payment-service",
          "effects": { "availability": 2.0, "throughputRps": 450, "latencyMs": -150 }
        },
        {
