          "effects": { "latencyMs": 2 }
        }
      ]
    },
    {
      "id": "async-payment-queue",
      "title": "Async Payment via Queue",
      "description": "Decouple payment processing by publishing to a message queue. Orders are confirmed immediately; payment is processed asynchronously, eliminating synchronous wait time in the critical path.",
