  "improvements": [
    {
      "id": "async-credit-rating-response",
      "title": "Async Credit Rating Response",
      "description": "Decouple the credit rating lookup using asynchronous messaging instead of waiting on the bureau synchronously. Meaningfully improves the Credit Rating Adapter's availability and frees up capacity, though the latency win is smaller than caching.",
      "learnMoreSlug": "async-messaging",
      "cost": { "yearlyOperational": 8000, "oneTimeInvestment": 10000 },
      "appliesTo": [
        { "targetId": "credit-rating-adapter", "effects": { "availability": 0.25, "throughputRps": 10 } },
        { "targetId": "get-customer-credit-rating", "effects": { "latencyMs": -90, "failRate": -0.006 } },
        { "targetId": "credit-rating-access", "effects": { "bandwidthRps": 15 } }
      ]
    },
    {
      "id": "cache-credit-rating-response",
      "title": "Cache Credit Rating Responses",
      "description": "Cache the Credit Rating Adapter's responses for repeat lookups instead of always hitting the external bureau. Cuts latency and load sharply, with a smaller availability gain than full async decoupling.",
      "learnMoreSlug": "caching-strategies",
      "cost": { "yearlyOperational": 5000, "oneTimeInvestment": 10000 },
      "appliesTo": [
        { "targetId": "credit-rating-adapter", "effects": { "availability": 0.12, "throughputRps": 15 } },
        { "targetId": "get-customer-credit-rating", "effects": { "latencyMs": -150, "bandwidthRps": 30, "failRate": -0.01 } }
      ]
    },
    {
