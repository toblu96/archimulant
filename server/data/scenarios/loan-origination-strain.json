      "cost": { "yearlyOperational": 7000, "oneTimeInvestment": 15000 },
      "appliesTo": [
        { "targetId": "customer-data-service", "effects": { "availability": 0.25 } },
        { "targetId": "get-customer-data", "effects": { "latencyMs": -90, "failRate": -0.006 } }
      ]
    },
    {
