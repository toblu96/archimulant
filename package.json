    "better-auth": "^1.6.14",
    "better-sqlite3": "^12.10.0",
    "evlog": "^2.18.1",
    "nuxt": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.3"
  },
  "packageManager": "pnpm@11.5.2"
